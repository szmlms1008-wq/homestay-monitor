# 第三方 API 密钥配置
# 复制此文件为 .env 并填入你的密钥

# 高德地图 API Key（用于 GPS 逆地理编码 + POI 附近搜索）
# 免费申请: https://lbs.amap.com/api/webservice/create-project
AMAP_KEY=

# 爬虫服务端口（可选，默认 9000）
CRAWLER_PORT=9000

# Node.js 服务端口（可选，默认 3002）
PORT=3002

# JWT 密钥（可选，生产环境请修改）
JWT_SECRET=homestay-monitor-secret-change-in-production

# Server酱 微信告警（可选，不填则不启用）
ALERT_SCKEY=
